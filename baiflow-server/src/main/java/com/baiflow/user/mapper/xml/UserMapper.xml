<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.baiflow.user.mapper.UserMapper">
    <sql id="userColumns">id, username, password_hash, display_name, role, status, last_login_at, created_at, updated_at</sql>
    <sql id="userWhere">
        <if test="role != null and role != ''">AND role = #{role}</if>
        <if test="status != null and status != ''">AND status = #{status}</if>
    </sql>
    <select id="selectByRole" resultType="com.baiflow.user.entity.User">
        SELECT <include refid="userColumns"/> FROM `user` WHERE 1=1 <include refid="userWhere"/> ORDER BY created_at DESC
    </select>
    <select id="selectAllOrdered" resultType="com.baiflow.user.entity.User">
        SELECT <include refid="userColumns"/> FROM `user` WHERE 1=1 <include refid="userWhere"/> ORDER BY created_at DESC
    </select>
</mapper>
