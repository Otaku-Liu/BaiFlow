<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.baiflow.share.mapper.ShareLinkMapper">
    <sql id="slColumns">id,target_file_item_id,created_by,token_hash,extraction_code_hash,share_type,access_mode,expires_at,max_views,view_count,max_downloads,download_count,require_private_password,status,created_at,updated_at</sql>
    <select id="selectByCreator" resultType="com.baiflow.share.entity.ShareLink">
        SELECT <include refid="slColumns"/> FROM share_link
        WHERE created_by=#{createdBy}
        <if test="status!=null and status!=''">AND status=#{status}</if>
        ORDER BY created_at DESC LIMIT #{offset},#{limit}
    </select>
    <select id="countByCreator" resultType="int">
        SELECT COUNT(*) FROM share_link WHERE created_by=#{createdBy}
        <if test="status!=null and status!=''">AND status=#{status}</if>
    </select>
    <select id="selectAll" resultType="com.baiflow.share.entity.ShareLink">
        SELECT <include refid="slColumns"/> FROM share_link
        <where><if test="status!=null and status!=''">status=#{status}</if></where>
        ORDER BY created_at DESC LIMIT #{offset},#{limit}
    </select>
    <select id="countAll" resultType="int">
        SELECT COUNT(*) FROM share_link
        <where><if test="status!=null and status!=''">status=#{status}</if></where>
    </select>
</mapper>
